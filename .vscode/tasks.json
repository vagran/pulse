{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run unit tests",
            "type": "shell",
            "command": "build/pulse_test"
        },
        {
            "label": "Run unit tests (Valgrind)",
            "type": "shell",
            "command": "valgrind --leak-check=full build/pulse_test"
        },
        {
            "label": "Run malloc unit tests",
            "type": "shell",
            "command": "cmake --build build --target run_malloc_tests"
        },
        {
            "label": "Upload firmware",
            "type": "shell",
            "command": "st-flash write ${workspaceFolder}/build/firmware.bin 0x08000000"
        },
        {
            "label": "Reset MCU",
            "type": "shell",
            "command": "st-flash reset"
        }
    ]
}
